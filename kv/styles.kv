#:import hex kivy.utils.get_color_from_hex

# --- CORES PREDEFINIDAS --- #
#:set text_color_light hex("#fbfcfb")
#:set text_color_dark hex("#2d3e38")
#:set primary_color hex("#2d3e38")
#:set primary_active_color hex("#1f2926")
#:set card_color hex("#dbedd4")
#:set card_active_color hex("#b4c4ae")


# --- LAYOUTS --- #
<VBoxContainer@BoxLayout>:
    orientation: "vertical"
    spacing: dp(16)
    padding: dp(16)

<TitleContainer@BoxLayout>:
    orientation: "vertical"
    padding: [0, 0, 0, dp(16)]
    spacing: dp(8)
    size_hint_y: None
    height: self.minimum_height

<ActionHeader@BoxLayout>:
    orientation: "horizontal"
    size_hint_y: None
    height: dp(56)
    padding: [dp(16), dp(0), dp(16), dp(0)]


# --- TEXTOS --- #
<CLabel@Label>:
    text_size: self.width, None
    size_hint_y: None
    height: self.texture_size[1]

<TextHeadline@CLabel>:
    font_name: 'headline_font'
    halign: "left"
    valign: "top"
    color: text_color_dark
    font_size: "32sp"
    bold: True

<TextBody@CLabel>:
    font_name: 'body_font'
    halign: "left"
    valign: "top"
    color: text_color_dark
    font_size: "16sp"
    bold: False

<TextButton@CLabel>:
    color: text_color_light
    font_size: "16sp"
    bold: True


# --- BOTÕES --- #
<CButton@Button>:
    font_name: 'body_font'
    size_hint_y: None
    height: dp(48)
    font_size: "16sp"
    bold: True
    background_color: 0, 0, 0, 0
    background_normal: ""

<PrimaryButton@CButton>:
    canvas.before:
        Color:
            rgba: primary_color if self.state == "normal" else primary_active_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)]

<CardButton@Button>:
    texto: "Botão"
    icone: ""
    size_hint_y: None
    height: container.minimum_height
    font_size: "16sp"
    bold: True
    background_color: 0, 0, 0, 0
    background_normal: ""
    canvas.before:
        Color:
            rgba: card_color if self.state == "normal" else card_active_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)]

    BoxLayout:
        id: container
        pos: root.pos
        width: root.width
        size_hint_y: None
        height: self.minimum_height
        orientation: "horizontal"
        padding: dp(16)
        spacing: dp(16)

        Image:
            source: root.icone
            size_hint: (None, None)
            size: ('24dp', '24dp')
            pos_hint: {'center_y': 0.5}
            allow_stretch: True

        Label:
            font_name: 'body_font'
            text: root.texto
            bold: True
            color: text_color_dark
            font_size: '16sp'
            size_hint_y: None
            text_size: self.width, None
            height: self.texture_size[1]
            pos_hint: {'center_y': 0.5}
            halign: "left"
            valign: "middle"

<GridButton@Button>:
    texto: "Botão"
    icone: ""
    size_hint_y: None
    height: container.minimum_height
    font_size: "16sp"
    bold: True
    background_color: 0, 0, 0, 0
    background_normal: ""
    canvas.before:
        Color:
            rgba: card_color if self.state == "normal" else card_active_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)]

    BoxLayout:
        id: container
        pos: root.pos
        width: root.width
        size_hint_y: None
        height: self.minimum_height
        orientation: "vertical"
        padding: dp(16)
        spacing: dp(8)

        Image:
            source: root.icone
            size_hint: (None, None)
            size: ('24dp', '24dp')
            pos_hint: {'center_y': 0.5}
            allow_stretch: True

        Label:
            font_name: 'body_font'
            text: root.texto
            bold: True
            color: text_color_dark
            font_size: '16sp'
            size_hint_y: None
            text_size: self.width, None
            height: self.texture_size[1]
            pos_hint: {'center_y': 0.5}
            halign: "left"
            valign: "middle"

<LockCardButton@Button>:
    texto: "Botão"
    icone: ""
    size_hint_y: None
    height: container.minimum_height
    font_size: "16sp"
    bold: True
    background_color: 0, 0, 0, 0
    background_normal: ""
    canvas.before:
        Color:
            rgba: card_active_color if self.state == "normal" else card_active_color
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(16)]

    BoxLayout:
        id: container
        pos: root.pos
        width: root.width
        size_hint_y: None
        height: self.minimum_height
        orientation: "horizontal"
        padding: dp(16)
        spacing: dp(16)

        Image:
            source: root.icone
            size_hint: (None, None)
            size: ('24dp', '24dp')
            pos_hint: {'center_y': 0.5}
            allow_stretch: True

        Label:
            text: root.texto
            bold: True
            color: text_color_dark
            font_size: '16sp'
            size_hint_y: None
            text_size: self.width, None
            height: self.texture_size[1]
            pos_hint: {'center_y': 0.5}
            halign: "left"
            valign: "middle"

<BackButton@Button>:
    background_color: 0, 0, 0, 0
    size_hint: None, None
    size: dp(56), dp(56)
    canvas.after:
        Color:
            rgba: primary_color if self.state == 'normal' else primary_active_color
        Line:
            points:
                [self.x + dp(15), self.center_y + dp(10),
                self.x + dp(5), self.center_y,
                self.x + dp(15), self.center_y - dp(10)]
            width: dp(2.5)

# --- FORMULÁRIOS --- #
<CInput@TextInput>:
    # Configurações de tamanho e comportamento
    size_hint_y: None
    height: dp(48)
    multiline: False
    write_tab: False

    # Remove os fundos padrão para usar o desenho customizado
    background_normal: ''
    background_active: ''
    background_color: 0, 0, 0, 0

    foreground_color: primary_color
    cursor_color: primary_color

    padding: [dp(15), (self.height - self.line_height) / 2]

    canvas.after:
        Color:
            rgba: primary_color if self.focus else primary_color
        Line:
            width: dp(1) if self.focus else dp(0.5)
            rounded_rectangle: (self.x, self.y, self.width, self.height, dp(12))


# --- BARRA DE PROGRESSO --- #
<BarraProgressoLimpa@Widget>:
    max: 100
    value: 0

    size_hint_y: None
    height: dp(32)
    canvas.before:
        # Cor de fundo
        Color:
            rgba: primary_color
        Line:
            width: dp(0.5)
            rounded_rectangle: [self.x, self.y, self.width, self.height, dp(12)]

        # Preenchimento
        Color:
            rgba: primary_color
        RoundedRectangle:
            pos: self.pos
            size: (self.width * (self.value / float(self.max)) if self.max > 0 else 0, self.height)
            radius: [dp(12)]