<LoginScreen>:
    BoxLayout:
        orientation: "vertical"

        VBoxContainer:
            Image:
                source: "media/images/splash.png"
                size_hint_y: None
                height: dp(200)
                allow_stretch: True
                keep_ratio: True

            TextHeadline:
                font_size: "40sp"
                halign: "center"
                text: "Ecociclo"

            TextBody:
                halign: "center"
                text: "Digite o código da comunidade"

            CInput:
                id: community_name
                hint_text: "Ex.: CA01"

            Widget

            PrimaryButton:
                text: "Entrar"
                on_release:
                    root.manager.transition.direction = "left"
                    root.manager.current = "Home"