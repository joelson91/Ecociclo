<NewsScreen>:
    BoxLayout:
        orientation: "vertical"

        ActionHeader:
            BackButton:
                on_release:
                    root.manager.transition.direction = "right"
                    root.manager.current = "Home"

        ScrollView:
            do_scroll_x: False
            do_scroll_y: True

            VBoxContainer:
                TitleContainer:
                    TextHeadline:
                        text: "Notícias"

                    TextBody:
                        text: "Notícias ambientais e avisos gerais"

                NewsButton:
                    fonte: "G1"
                    titulo: "Novos métodos de descarte são aplaudidos pelo governo"
                    icone: "media/icons/news.png"

                NewsButton:
                    fonte: "Centro Comunitário"
                    titulo: "Em agosto será feita a reforma do posto de coleta"
                    icone: "media/icons/news.png"

                Widget

