<NewsScreen>:
    BoxLayout:
        orientation: "vertical"

        ActionHeader:
            BackButton:
                on_release:
                    root.manager.transition.direction = "right"
                    root.manager.current = "Home"

        VBoxContainer:
            TitleContainer:
                TextHeadline:
                    text: "Notícias"

                TextBody:
                    text: "Notícias ambientais e avisos gerais"

            CardButton:
                texto: "Criar composteira local"
                icone: "media/icons/eco.png"

            CardButton:
                texto: "Criar ponto de coleta de plásticos"
                icone: "media/icons/eco.png"

            Widget

