<HomeScreen>:
    BoxLayout:
        orientation: "vertical"

        Widget:
            size_hint_y: None
            height: dp(56)

        VBoxContainer:
            TextHeadline:
                text: "Comunidade Cupiúba"

            TextBody:
                text: "Castanhal"

            CardButton:
                texto: "Aprender"
                icone: "media/icons/book.png"
                on_release:
                    root.manager.transition.direction = "left"
                    root.manager.current = "Learn"

            CardButton:
                texto: "Metas"
                icone: "media/icons/target.png"

            CardButton:
                texto: "Notícias"
                icone: "media/icons/news.png"

            CardButton:
                texto: "Sobre a comunidade"
                icone: "media/icons/info.png"

            Widget