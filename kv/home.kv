<HomeScreen>:
    BoxLayout:
        orientation: "vertical"

        Widget:
            size_hint_y: None
            height: dp(56)

        VBoxContainer:
            TitleContainer:
                TextHeadline:
                    text: "Comunidade Cupiúba"

                TextBody:
                    text: "Castanhal"

            # 1. DECLARAÇÃO DA BARRA DE PROGRESSO
            TitleContainer:
                TextBody:
                    text: "Seu progresso"
                    bold: True

                BarraProgressoLimpa:
                    id: minha_barra
                    max: 100
                    value: 25

            GridLayout:
                cols: 2
                spacing: dp(16)

                GridButton:
                    texto: "Aprender"
                    icone: "media/icons/book.png"
                    on_release:
                        root.manager.transition.direction = "left"
                        root.manager.current = "Learn"

                GridButton:
                    texto: "Metas"
                    icone: "media/icons/target.png"

                GridButton:
                    texto: "Notícias"
                    icone: "media/icons/news.png"

                GridButton:
                    texto: "Sobre"
                    icone: "media/icons/info.png"

            Widget